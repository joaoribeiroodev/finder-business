# =============================================================================
# Finder Business - variaveis de ambiente
# =============================================================================

# -- PostgreSQL --
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_esta_senha
POSTGRES_DB=finder_business
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:altere_esta_senha@localhost:5432/finder_business

# -- OpenAI --
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4

# -- Aplicacao --
APP_PORT=3000
NODE_ENV=development

# -- Scraper --
SCRAPER_MAX_PLACES=30
SCRAPER_TIMEOUT_MS=60000

# -- Playwright (Docker) --
PLAYWRIGHT_CHROMIUM_SANDBOX=0
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright

# -- Seguranca (opcional - deixe vazio para desabilitar auth) --
APP_PASSWORD=
AUTH_SECRET=

# -- Rate limiting --
RATE_LIMIT_SCRAPER=5
RATE_LIMIT_OPENAI=30
